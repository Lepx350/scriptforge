generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id                      String   @id @default(uuid())
  title                   String
  status                  String   @default("draft") // draft, in_production, editing, published
  inputScript             String   @db.Text
  inputMethod             String   @default("paste") // paste, upload
  originalFilename        String?
  estimatedDurationMinutes Int?
  youtubeUrl              String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  visualDirections    VisualDirection[]
  audioDirections     AudioDirection[]
  timelineSegments    TimelineSegment[]
  productionPackage   ProductionPackage?
  analytics           Analytics[]

  @@index([status])
  @@index([createdAt])
}

model VisualDirection {
  id             String   @id @default(uuid())
  projectId      String
  sectionIndex   Int
  scriptText     String   @db.Text
  layerType      String   // 3d, media, gfx
  directionText  String   @db.Text
  aiPrompt       String?  @db.Text
  imageUrl       String?  // Vercel Blob URL for generated image
  imageBase64    String?  @db.Text // Base64 fallback if blob storage unavailable
  mediaLinks     String?  @db.Text // JSON string
  gfxSpecs       String?  @db.Text // JSON string
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([sectionIndex])
}

model AudioDirection {
  id              String   @id @default(uuid())
  projectId       String
  sectionIndex    Int
  scriptText      String   @db.Text
  musicMood       String
  musicBpmRange   String
  musicSearchTerms String  @db.Text
  sfxCues         String?  @db.Text // JSON string
  voiceoverUrl    String?
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([sectionIndex])
}

model TimelineSegment {
  id             String   @id @default(uuid())
  projectId      String
  segmentIndex   Int
  startTime      String
  durationSeconds Int
  narrationText  String   @db.Text
  visualLayers   String?  @db.Text // JSON string
  audioNotes     String?  @db.Text // JSON string
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([segmentIndex])
}

model ProductionPackage {
  id                String   @id @default(uuid())
  projectId         String   @unique
  titles            String?  @db.Text // JSON string
  thumbnailConcepts String?  @db.Text // JSON string
  description       String?  @db.Text
  tags              String?  @db.Text
  createdAt         DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Analytics {
  id              String   @id @default(uuid())
  projectId       String
  views           Int      @default(0)
  watchTimeHours  Float    @default(0)
  avgViewDuration String?
  ctr             Float    @default(0)
  subscriberGain  Int      @default(0)
  fetchedAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Settings {
  id          String   @id @default("default")
  geminiKey   String?
  coreModel   String?
  visualModel String?
  updatedAt   DateTime @updatedAt
}
